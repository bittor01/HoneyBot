# Discord Bot Token
DISCORD_TOKEN=your_token_here

# Comma-separated list of channel IDs to monitor
MONITORED_CHANNELS=123456789012345678,901234567890123456

# Channel ID where ban logs should be sent
LOG_CHANNEL_ID=123456789012345678

# Ban Reason (Optional, leave blank for silent ban)
BAN_REASON=Posted in a honeypot channel.

# Notice Embed Settings
NOTICE_TITLE=⚠️ WARNING: DO NOT POST HERE ⚠️
NOTICE_BODY=This channel is for monitoring only. Any posts here will result in an immediate and permanent ban.
